// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTICATION MODELS
// ============================================

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  sessions  Session[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// COMPANY & PLATFORM MODELS
// ============================================

model Company {
  id          String   @id @default(cuid())
  name        String
  website     String?
  industry    String?
  description String?
  logoUrl     String?
  userId      String   @default("temp-user-001")

  platforms         Platform[]
  contentSettings   ContentSettings?
  generatedPosts    GeneratedPost[]
  media             Media[]
  intelligence      CompanyIntelligence?
  contentQueueItems ContentQueueItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Platform {
  id             String       @id @default(cuid())
  companyId      String
  type           PlatformType
  name           String
  username       String?
  isConnected    Boolean      @default(false)
  connectionData Json?
  lastSyncAt     DateTime?

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  generatedPosts    GeneratedPost[]
  contentQueueItems ContentQueueItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PlatformType {
  LINKEDIN
  FACEBOOK
  TWITTER
  INSTAGRAM
  WORDPRESS
}

// ============================================
// CONTENT SETTINGS (Legacy - kept for compatibility)
// ============================================

model ContentSettings {
  id        String @id @default(cuid())
  companyId String @unique

  tone          String   @default("professional")
  topics        String[]
  keywords      String[]
  postFrequency Int      @default(7)

  includeHashtags Boolean @default(true)
  includeEmojis   Boolean @default(false)
  maxLength       Int?

  brandVoice      String?
  avoidTopics     String[]

  defaultPostingTimes String[] @default(["09:00", "14:00", "18:00"])
  timezone            String   @default("Africa/Johannesburg")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// MEDIA LIBRARY (ENHANCED)
// ============================================

model Media {
  id        String @id @default(cuid())
  companyId String

  filename     String
  url          String
  thumbnailUrl String?
  type         MediaType
  mimeType     String?
  size         Int
  width        Int?
  height       Int?
  altText      String?

  // Pillar & Tag associations
  pillarIds    String[]  // References to ContentPillar IDs
  tags         String[]  // Custom tags (e.g., "pasta", "team photo")

  // Content type hints (educational, engagement, social_proof, promotional)
  contentTypes String[]

  // Usage tracking
  usageCount Int       @default(0)
  lastUsedAt DateTime?

  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  postMedia PostMedia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, createdAt])
}

enum MediaType {
  IMAGE
  VIDEO
  GIF
}

// ============================================
// GENERATED POSTS & SCHEDULING
// ============================================

model GeneratedPost {
  id         String @id @default(cuid())
  companyId  String
  platformId String

  title    String?
  content  String
  hashtags String[]

  postMedia PostMedia[]

  scheduledFor DateTime?
  publishedAt  DateTime?
  status       PostStatus @default(DRAFT)

  isPartOfBulk   Boolean @default(false)
  bulkScheduleId String?

  generatedBy String  @default("groq-llama-3.3")
  prompt      String?
  topic       String?
  tone        String?
  iteration   Int     @default(1)

  pillar        String?
  contentType   String?
  includesHumor Boolean @default(false)
  hook          String?

  externalPostId  String?
  externalPostUrl String?
  lastSyncedAt    DateTime?

  likes       Int @default(0)
  comments    Int @default(0)
  shares      Int @default(0)
  impressions Int @default(0)

  engagementRate   Float?
  performanceScore Float?

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  platform Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([platformId, scheduledFor])
  @@index([status, scheduledFor])
  @@index([bulkScheduleId])
  @@index([externalPostId])
  @@index([pillar])
  @@index([contentType])
  @@index([publishedAt])
}

model PostMedia {
  id      String @id @default(cuid())
  postId  String
  mediaId String
  order   Int    @default(0)

  post  GeneratedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  media Media         @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([postId, mediaId])
  @@index([postId])
  @@index([mediaId])
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  ARCHIVED
}

// ============================================
// BULK SCHEDULE TRACKING
// ============================================

model BulkSchedule {
  id        String @id @default(cuid())
  companyId String

  name        String?
  startDate   DateTime
  endDate     DateTime
  postsCount  Int
  timesPerDay String[]
  platforms   String[]

  status BulkScheduleStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

enum BulkScheduleStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// ============================================
// V3: CONTENT INTELLIGENCE SYSTEM
// ============================================

model CompanyIntelligence {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  brandPersonality    String[]
  brandVoice          String?
  uniqueSellingPoints String[]
  targetAudience      String?

  primaryGoals   String[]
  communityFocus String?

  contentPillars ContentPillar[]

  primaryKeywords  String[]
  industryHashtags String[]
  brandedHashtags  String[]

  defaultTone     String   @default("professional")
  humorEnabled    Boolean  @default(true)
  humorStyle      String?
  humorDays       String[]
  humorTimes      String[]
  dayToneSchedule Json?

  postsPerWeek   Int      @default(4)
  preferredDays  String[]
  preferredTimes Json?
  timezone       String   @default("Africa/Johannesburg")
  autoApprove    Boolean  @default(false)

  learnedBestDays    String[]
  learnedBestTimes   Json?
  learnedBestPillars Json?
  avoidTopics        String[]

  intelligenceScore      Int       @default(0)
  engagementTrend        String?
  avgEngagementRate      Float?
  topPerformingTypes     Json?
  topPerformingTopics    Json?
  topPerformingHooks     Json?
  topicUsageHistory      Json?
  contentTypePerformance Json?
  platformPerformance    Json?
  lastIntelligenceUpdate DateTime?
  weeklyPostTarget       Int?

  competitors    Competitor[]
  competitorGaps String[]

  industryBenchmarks Json?
  industryTrends     Json?

  onboardingCompleted Boolean   @default(false)
  lastResearchSync    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentPillar {
  id             String              @id @default(cuid())
  intelligenceId String
  intelligence   CompanyIntelligence @relation(fields: [intelligenceId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  topics       String[]
  keywords     String[]
  contentTypes String[]

  frequencyWeight Float    @default(1.0)
  preferredDays   String[]

  totalPosts    Int    @default(0)
  avgEngagement Float?

  lastUsed           DateTime?
  performanceTrend   String?
  bestPerformingType String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([intelligenceId])
}

model Competitor {
  id             String              @id @default(cuid())
  intelligenceId String
  intelligence   CompanyIntelligence @relation(fields: [intelligenceId], references: [id], onDelete: Cascade)

  name        String
  linkedinUrl String?
  facebookUrl String?
  websiteUrl  String?

  postingFrequency String?
  avgEngagement    Float?
  followerCount    Int?
  topContentTypes  String[]
  topHashtags      String[]
  strengths        String[]
  weaknesses       String[]

  lastAnalyzed DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([intelligenceId])
}

model IndustryBenchmark {
  id       String @id @default(cuid())
  industry String @unique

  recommendedPostsPerWeek Int      @default(4)
  optimalPostsMin         Int      @default(3)
  optimalPostsMax         Int      @default(5)
  bestDays                String[]
  bestTimes               Json

  platformPriority Json

  suggestedThemes Json

  topHashtags String[]
  seoKeywords String[]

  recommendedTone  String  @default("professional")
  humorAppropriate Boolean @default(true)

  avgEngagementRate Float?

  contentMixRecommendation Json?
  growthBenchmarks         Json?

  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([industry])
}

model ContentQueueItem {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  content  String
  hashtags String[]
  keywords String[]

  platformId    String
  platform      Platform @relation(fields: [platformId], references: [id])
  suggestedDate DateTime
  suggestedTime String

  pillar        String?
  contentType   String?
  tone          String?
  includesHumor Boolean  @default(false)
  hook          String?

  engagementPrediction String?
  predictedScore       Float?
  suggestedMedia       String?
  generationContext    Json?

  status      QueueStatus @default(PENDING)
  reviewedAt  DateTime?
  reviewNotes String?

  generatedPostId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([platformId])
  @@index([suggestedDate])
  @@index([contentType])
}

enum QueueStatus {
  PENDING
  APPROVED
  REJECTED
  REGENERATING
  SCHEDULED
}