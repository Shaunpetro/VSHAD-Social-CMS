// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTICATION MODELS
// ============================================

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  sessions  Session[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// COMPANY & PLATFORM MODELS
// ============================================

model Company {
  id          String   @id @default(cuid())
  name        String
  website     String?
  industry    String?  // Legacy field - kept for backward compatibility
  description String?
  logoUrl     String?
  userId      String   @default("temp-user-001")

  platforms         Platform[]
  contentSettings   ContentSettings?
  generatedPosts    GeneratedPost[]
  media             Media[]
  intelligence      CompanyIntelligence?
  contentQueueItems ContentQueueItem[]
  documents         CompanyDocument[]      // NEW: Company profile documents

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Platform {
  id             String       @id @default(cuid())
  companyId      String
  type           PlatformType
  name           String
  username       String?
  isConnected    Boolean      @default(false)
  connectionData Json?
  lastSyncAt     DateTime?

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  generatedPosts    GeneratedPost[]
  contentQueueItems ContentQueueItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PlatformType {
  LINKEDIN
  FACEBOOK
  TWITTER
  INSTAGRAM
  WORDPRESS
}

// ============================================
// NEW: COMPANY DOCUMENTS (PDF Profiles, Brochures)
// ============================================

model CompanyDocument {
  id        String @id @default(cuid())
  companyId String

  type     String // 'company_profile' | 'capability_statement' | 'brochure' | 'other'
  filename String
  url      String // Vercel Blob URL or external URL
  mimeType String
  size     Int

  // Analysis tracking
  extractedText String?   @db.Text // Extracted text from PDF
  analyzedAt    DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

// ============================================
// CONTENT SETTINGS (Legacy - kept for compatibility)
// ============================================

model ContentSettings {
  id        String @id @default(cuid())
  companyId String @unique

  tone          String   @default("professional")
  topics        String[]
  keywords      String[]
  postFrequency Int      @default(7)

  includeHashtags Boolean @default(true)
  includeEmojis   Boolean @default(false)
  maxLength       Int?

  brandVoice  String?
  avoidTopics String[]

  defaultPostingTimes String[] @default(["09:00", "14:00", "18:00"])
  timezone            String   @default("Africa/Johannesburg")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// MEDIA LIBRARY (SMART SYSTEM WITH LIFECYCLE)
// ============================================

model Media {
  id        String @id @default(cuid())
  companyId String

  // File Information
  filename     String
  url          String
  thumbnailUrl String?
  type         MediaType
  mimeType     String?
  size         Int
  width        Int?
  height       Int?
  altText      String?

  // Categorization
  pillarIds    String[] // References to ContentPillar IDs
  tags         String[] // Custom tags (e.g., "pasta", "team photo")
  contentTypes String[] // educational, engagement, social_proof, promotional

  // Lifecycle Management
  isUsed       Boolean   @default(false)
  usedAt       DateTime?
  usedInPostId String? // Reference to the post that used this media
  expiresAt    DateTime // Auto-set to createdAt + 2 months

  // Auto-Selection
  autoSelect Boolean @default(true) // Include in auto-selection pool
  priority   Int     @default(0) // Higher = selected first (for expiring soon)

  // Usage Tracking (for analytics)
  usageCount Int       @default(0)
  lastUsedAt DateTime?

  // Relations
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  postMedia PostMedia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, createdAt])
  @@index([companyId, isUsed, expiresAt])
  @@index([companyId, autoSelect, isUsed])
}

enum MediaType {
  IMAGE
  VIDEO
  GIF
}

// ============================================
// GENERATED POSTS & SCHEDULING
// ============================================

model GeneratedPost {
  id         String @id @default(cuid())
  companyId  String
  platformId String

  title    String?
  content  String
  hashtags String[]

  postMedia PostMedia[]

  scheduledFor DateTime?
  publishedAt  DateTime?
  status       PostStatus @default(DRAFT)

  isPartOfBulk   Boolean @default(false)
  bulkScheduleId String?

  generatedBy String  @default("groq-llama-3.3")
  prompt      String?
  topic       String?
  tone        String?
  iteration   Int     @default(1)

  pillar        String?
  contentType   String?
  includesHumor Boolean @default(false)
  hook          String?

  externalPostId  String?
  externalPostUrl String?
  lastSyncedAt    DateTime?

  likes       Int @default(0)
  comments    Int @default(0)
  shares      Int @default(0)
  impressions Int @default(0)

  engagementRate   Float?
  performanceScore Float?

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  platform Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([platformId, scheduledFor])
  @@index([status, scheduledFor])
  @@index([bulkScheduleId])
  @@index([externalPostId])
  @@index([pillar])
  @@index([contentType])
  @@index([publishedAt])
}

model PostMedia {
  id      String @id @default(cuid())
  postId  String
  mediaId String
  order   Int    @default(0)

  post  GeneratedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  media Media         @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([postId, mediaId])
  @@index([postId])
  @@index([mediaId])
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  ARCHIVED
}

// ============================================
// BULK SCHEDULE TRACKING
// ============================================

model BulkSchedule {
  id        String @id @default(cuid())
  companyId String

  name        String?
  startDate   DateTime
  endDate     DateTime
  postsCount  Int
  timesPerDay String[]
  platforms   String[]

  status BulkScheduleStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

enum BulkScheduleStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// ============================================
// V3: CONTENT INTELLIGENCE SYSTEM
// ============================================

model CompanyIntelligence {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // ============================================
  // EXISTING: BRAND IDENTITY
  // ============================================
  brandPersonality    String[]
  brandVoice          String?
  uniqueSellingPoints String[]
  targetAudience      String?

  primaryGoals   String[]
  communityFocus String?

  contentPillars ContentPillar[]

  primaryKeywords  String[]
  industryHashtags String[]
  brandedHashtags  String[]

  // ============================================
  // EXISTING: TONE & HUMOR SETTINGS
  // ============================================
  defaultTone     String   @default("professional")
  humorEnabled    Boolean  @default(true)
  humorStyle      String?
  humorDays       String[]
  humorTimes      String[]
  dayToneSchedule Json?

  // ============================================
  // EXISTING: POSTING SCHEDULE
  // ============================================
  postsPerWeek   Int      @default(4)
  preferredDays  String[]
  preferredTimes Json?
  timezone       String   @default("Africa/Johannesburg")
  autoApprove    Boolean  @default(false)

  // ============================================
  // EXISTING: LEARNED INTELLIGENCE
  // ============================================
  learnedBestDays    String[]
  learnedBestTimes   Json?
  learnedBestPillars Json?
  avoidTopics        String[]

  intelligenceScore      Int       @default(0)
  engagementTrend        String?
  avgEngagementRate      Float?
  topPerformingTypes     Json?
  topPerformingTopics    Json?
  topPerformingHooks     Json?
  topicUsageHistory      Json?
  contentTypePerformance Json?
  platformPerformance    Json?
  lastIntelligenceUpdate DateTime?
  weeklyPostTarget       Int?

  // ============================================
  // EXISTING: COMPETITOR ANALYSIS
  // ============================================
  competitors    Competitor[]
  competitorGaps String[]

  industryBenchmarks Json?
  industryTrends     Json?

  onboardingCompleted Boolean   @default(false)
  lastResearchSync    DateTime?

  // ============================================
  // EXISTING: MEDIA CONTENT BALANCE SETTINGS
  // ============================================
  mediaBalanceEnabled Boolean @default(true)
  mediaPostRatio      Int     @default(60) // Percentage of posts with media (0-100)

  // Content-type specific ratios (percentage with media)
  educationalMediaRatio Int @default(50)
  engagementMediaRatio  Int @default(30)
  socialProofMediaRatio Int @default(80)
  promotionalMediaRatio Int @default(70)

  // Expiring media handling
  prioritizeExpiringMedia Boolean @default(true)
  expiryWarningDays       Int     @default(7) // Days before expiry to prioritize

  // ============================================
  // NEW: DATA SOURCES FOR AI ANALYSIS
  // ============================================
  // Stores URLs/references to data sources used for analysis
  // Format: { website: "url", linkedin: "url", pdfUrl: "url", manual: "text" }
  dataSources     Json?
  lastAnalyzedAt  DateTime?
  analysisVersion Int       @default(1) // Increment on each re-analysis

  // ============================================
  // NEW: AI ANALYSIS RESULTS
  // ============================================
  // Full structured analysis output from Groq
  aiAnalysis        Json?
  aiConfidenceScore Float? // Overall confidence 0-1

  // Extracted & User-Confirmable Data
  // Format: [{ code: "CONST_CE", name: "Civil Engineering", confidence: 0.95, cidbGrade: 7 }]
  extractedIndustries Json?

  // Format: [{ name: "Structural Steel", keywords: ["steel", "structural"], isCore: true }]
  extractedServices Json?

  // Format: [{ point: "CIDB Level 7 in 5 disciplines", category: "certification", evidence: "..." }]
  extractedUSPs Json?

  // Format: { businessType: "B2B", primarySectors: ["Mining"], decisionMakers: ["Procurement Managers"], ... }
  extractedAudience Json?

  // Format: { formality: "professional", personality: ["confident", "expert"], technicalLevel: "high" }
  extractedVoice Json?

  // Format: { bbeeLevel: 2, cidbGrades: { CE: 7, GB: 7 }, provinces: ["Gauteng"], industryBodies: ["SAFCEC"] }
  extractedSAContext Json?

  // ============================================
  // NEW: USER CONFIRMATION STATUS
  // ============================================
  industriesConfirmed Boolean @default(false)
  servicesConfirmed   Boolean @default(false)
  uspsConfirmed       Boolean @default(false)
  audienceConfirmed   Boolean @default(false)
  voiceConfirmed      Boolean @default(false)

  // ============================================
  // NEW: BUSINESS GOAL (User Selected)
  // ============================================
  // Drives content strategy: 'leads' | 'awareness' | 'recruitment' | 'engagement'
  primaryBusinessGoal String?
  secondaryGoals      String[]

  // ============================================
  // NEW: AUTO-GENERATED CONTENT STRATEGY
  // ============================================
  // Custom content mix based on goal + audience (overrides default 40-30-20-10)
  generatedContentMix Json?

  // Content themes per service/industry
  // Format: [{ theme: "Technical Expertise", purpose: "...", topicExamples: [...], frequency: "weekly" }]
  generatedThemes Json?

  // Specific topic suggestions ready for content generation
  generatedTopics Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentPillar {
  id             String              @id @default(cuid())
  intelligenceId String
  intelligence   CompanyIntelligence @relation(fields: [intelligenceId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  topics       String[]
  keywords     String[]
  contentTypes String[]

  frequencyWeight Float    @default(1.0)
  preferredDays   String[]

  totalPosts    Int    @default(0)
  avgEngagement Float?

  lastUsed           DateTime?
  performanceTrend   String?
  bestPerformingType String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([intelligenceId])
}

model Competitor {
  id             String              @id @default(cuid())
  intelligenceId String
  intelligence   CompanyIntelligence @relation(fields: [intelligenceId], references: [id], onDelete: Cascade)

  name        String
  linkedinUrl String?
  facebookUrl String?
  websiteUrl  String?

  postingFrequency String?
  avgEngagement    Float?
  followerCount    Int?
  topContentTypes  String[]
  topHashtags      String[]
  strengths        String[]
  weaknesses       String[]

  lastAnalyzed DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([intelligenceId])
}

model IndustryBenchmark {
  id       String @id @default(cuid())
  industry String @unique

  recommendedPostsPerWeek Int      @default(4)
  optimalPostsMin         Int      @default(3)
  optimalPostsMax         Int      @default(5)
  bestDays                String[]
  bestTimes               Json

  platformPriority Json

  suggestedThemes Json

  topHashtags String[]
  seoKeywords String[]

  recommendedTone  String  @default("professional")
  humorAppropriate Boolean @default(true)

  avgEngagementRate Float?

  contentMixRecommendation Json?
  growthBenchmarks         Json?

  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([industry])
}

model ContentQueueItem {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  content  String
  hashtags String[]
  keywords String[]

  platformId    String
  platform      Platform @relation(fields: [platformId], references: [id])
  suggestedDate DateTime
  suggestedTime String

  pillar        String?
  contentType   String?
  tone          String?
  includesHumor Boolean  @default(false)
  hook          String?

  engagementPrediction String?
  predictedScore       Float?
  suggestedMedia       String?
  generationContext    Json?

  status      QueueStatus @default(PENDING)
  reviewedAt  DateTime?
  reviewNotes String?

  generatedPostId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([platformId])
  @@index([suggestedDate])
  @@index([contentType])
}

enum QueueStatus {
  PENDING
  APPROVED
  REJECTED
  REGENERATING
  SCHEDULED
}