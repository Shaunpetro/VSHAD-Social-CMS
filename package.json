{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:auto": "node ./scripts/dev-with-tunnel.js",
    "dev:tunnel": "concurrently \"next dev --turbo\" \"ngrok http 3000\"",
    "ngrok": "ngrok http 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed:benchmarks": "npx tsx prisma/seed-benchmarks.ts",
    "seed:benchmarks:extended": "npx tsx prisma/seed-benchmarks-extended.ts"
  },
  "dependencies": {
    "@lucia-auth/adapter-prisma": "^4.0.1",
    "@prisma/client": "^6.1.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "lucia": "^3.2.2",
    "lucide-react": "^0.460.0",
    "next": "^15.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.4",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
