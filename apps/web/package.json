{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:auto": "cd ../.. && node scripts/dev-with-tunnel.js",
    "dev:ps": "cd ../.. && powershell -ExecutionPolicy Bypass -File scripts/dev-with-tunnel.ps1",
    "dev:tunnel": "concurrently \"next dev --turbo\" \"ngrok http 3000\"",
    "ngrok": "ngrok http 3000",
    "build": "prisma generate --schema=../../prisma/schema.prisma && next build",
    "postinstall": "prisma generate --schema=../../prisma/schema.prisma",
    "start": "next start",
    "lint": "next lint",
    "seed:metrics": "node ../../scripts/seed-metrics.js"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@google/generative-ai": "^0.24.1",
    "@lucia-auth/adapter-prisma": "^4.0.1",
    "@prisma/client": "6.1.0",
    "@uploadthing/react": "^7.3.3",
    "@vercel/blob": "^2.3.3",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.0",
    "groq-sdk": "^1.1.1",
    "lucia": "^3.2.2",
    "lucide-react": "^0.460.0",
    "next": "^15.0.4",
    "openai": "^6.27.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-image-crop": "^11.0.10",
    "recharts": "^3.8.0",
    "tailwind-merge": "^2.6.0",
    "uploadthing": "^7.7.4"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.4",
    "postcss": "^8.4.0",
    "prisma": "6.1.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.2"
  }
}
